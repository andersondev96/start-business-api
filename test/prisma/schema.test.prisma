generator client {
    provider = "prisma-client-js"
    output   = "../../src/database/test-client"
}

datasource db {
    provider = "sqlite"
}

enum Role {
  ADMIN
  ENTREPRENEUR
  CUSTOMER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar    String?

  role Role @default(CUSTOMER)

  @@map("users")
}
